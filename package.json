{
    "name": "platform",
    "private": true,
    "scripts": {
        "store": "lerna run --scope=@adrian.insua/ngredux-store --parallel",
        "form": "lerna run --scope=@adrian.insua/ngredux-form --parallel",
        "router": "lerna run --scope=@adrian.insua/ngredux-router --parallel",
        "build": "lerna run build --stream",
        "clean": "npm-run-all -p clean:*",
        "clean:deps": "npm-run-all -p clean:deps:*",
        "clean:deps:workspace": "rimraf node_modules",
        "clean:deps:packages": "rimraf packages/*/node_modules",
        "clean:coverage": "rimraf coverage",
        "clean:dist": "rimraf packages/*/dist",
        "lint": "eslint packages/**/*.{js,ts} --fix",
        "test": "jest --coverage",
        "test:ci": "jest --coverage --ci --maxWorkers=2",
        "test:watch": "jest --watch",
        "commit": "commit",
        "postinstall": "npm run bootstrap",
        "bootstrap": "lerna bootstrap --force-local"
    },
    "engines": {
        "node": ">=18"
    },
    "devDependencies": {
        "@angular-devkit/build-angular": "~18.2.14",
        "@angular/animations": "18.2.13",
        "@angular/cli": "18.2.14",
        "@angular/common": "18.2.13",
        "@angular/compiler": "18.2.13",
        "@angular/compiler-cli": "18.2.13",
        "@angular/core": "18.2.13",
        "@angular/forms": "18.2.13",
        "@angular/platform-browser": "18.2.13",
        "@angular/platform-browser-dynamic": "18.2.13",
        "@angular/router": "18.2.13",
        "@commitlint/cli": "7.3.2",
        "@commitlint/config-conventional": "7.3.1",
        "@commitlint/prompt-cli": "7.3.1",
        "@semantic-release/changelog": "^6.0.3",
        "@semantic-release/commit-analyzer": "^13.0.1",
        "@semantic-release/git": "^10.0.1",
        "@semantic-release/github": "^11.0.6",
        "@semantic-release/npm": "^12.0.2",
        "@semantic-release/release-notes-generator": "^14.1.0",
        "@types/jest": "^29.0.0",
        "eslint": "^8.0.0",
        "husky": "1.3.1",
        "jest": "^29.0.0",
        "jest-preset-angular": "^14.0.0",
        "lerna": "^4.0.0",
        "ng-packagr": "^18.2.1",
        "npm-run-all": "4.1.5",
        "prettier": "1.15.3",
        "redux": "4.0.1",
        "redux-devtools-extension": "^2.13.9",
        "rimraf": "2.6.3",
        "rxjs": "7.8.0",
        "semantic-release": "^24.2.9",
        "ts-node": "~10.9.0",
        "tslib": "^2.0.0",
        "typescript": "~5.4.0",
        "zone.js": "~0.14.10"
    },
    "version": "11.0.0"
}
