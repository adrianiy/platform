{
    "extends": "./tsconfig.json",
    "compilerOptions": {
        "outDir": "../../out-tsc/lib",
        "target": "ES2022",
        "allowSyntheticDefaultImports": true,
        "declaration": true,
        "declarationMap": true,
        "inlineSources": true,
        "skipLibCheck": true,
        "types": [],
        "lib": [
            "dom",
            "ES2022"
        ]
    },
    "angularCompilerOptions": {
        "compilationMode": "partial"
    },
    "exclude": [
        "src/test.ts",
        "**/*.spec.ts"
    ]
}
